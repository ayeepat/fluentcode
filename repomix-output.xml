          exercise: {
            prompt: `Print three items "red", "green", "blue" separated by " * " (space asterisk space).`,
            starterCode: `# Use sep=`,
            solution: `print("red", "green", "blue", sep=" * ")`,
            tests: [{ type: "contains", value: "sep=" }],
            debuggingTip: `sep must be a string – use quotes.`
          }
        }
      ]
    },
