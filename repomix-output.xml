          </span>
        </motion.div>

        <motion.h1
          {...fadeUp(0.1)}
          className="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-[0.92] tracking-tight mb-6 max-w-4xl"
        >
          Learn to code.
          <br />
          <span className="text-zinc-400 font-semibold">Actually learn it.</span>
        </motion.h1>

        <motion.p
          {...fadeUp(0.18)}
